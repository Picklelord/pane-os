<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<AssemblyName>paneosinteractivecomputer</AssemblyName>
		<PackageId>paneosinteractivecomputer</PackageId>
		<LangVersion>14</LangVersion>
		<NoWarn>1701;1702;1591;</NoWarn>
		<WarningsAsErrors></WarningsAsErrors>
		<TreatWarningsAsErrors>False</TreatWarningsAsErrors>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<DefineConstants>SANDBOX</DefineConstants>
		<AllowUnsafeBlocks>False</AllowUnsafeBlocks>
		<OutputPath>../../../../../Repositories/sbox-public/game/.vs/output/</OutputPath>
		<DocumentationFile>../../../../../Repositories/sbox-public/game/.vs/output/paneosinteractivecomputer.xml</DocumentationFile>
		<RootNamespace>Sandbox</RootNamespace>
		<Nullable>disable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<Using Include="Sandbox.Internal.GlobalGameNamespace" Static="true" />
		<Using Include="Microsoft.AspNetCore.Components" />
		<Using Include="Microsoft.AspNetCore.Components.Rendering" />
	</ItemGroup>

	<ItemGroup>
		<Analyzer Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.CodeUpgrader.dll"/> 
		<Analyzer Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.Generator.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.System.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.Engine.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.Filesystem.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.Reflection.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Sandbox.Mounting.dll"/> 
		<Reference Include="../../../../../Repositories/sbox-public/game/bin/managed/Microsoft.AspNetCore.Components.dll"/> 
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="../../../../../Repositories/sbox-public/game/addons/base/code/Base Library.csproj" />
	</ItemGroup>

</Project>

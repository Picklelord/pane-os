@namespace PaneOS.InteractiveComputer
@using PaneOS.InteractiveComputer
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Sandbox
@using Sandbox.UI
@inherits Panel

<root class="app-host"></root>

@code
{
	[Parameter] public ComputerRunningApp? Instance { get; set; }
	private string? mountedInstanceId;

	private Panel HostPanel => Children.FirstOrDefault() ?? this;

	protected override int BuildHash()
	{
		unchecked
		{
			var hash = 17;
			hash = hash * 31 + (Instance?.State.InstanceId?.GetHashCode() ?? 0);
			hash = hash * 31 + (Instance?.State.Data.Count ?? 0);
			return hash;
		}
	}

	protected override void OnAfterTreeRender( bool firstTime )
	{
		base.OnAfterTreeRender( firstTime );

		if ( Instance?.Session.Content is null )
			return;

		var hostPanel = HostPanel;
		if ( mountedInstanceId == Instance.State.InstanceId && Instance.Session.Content.Parent == hostPanel )
			return;

		if ( Instance.Session.Content.Parent != hostPanel )
			Instance.Session.Content.Parent = hostPanel;

		mountedInstanceId = Instance.State.InstanceId;
	}
}
